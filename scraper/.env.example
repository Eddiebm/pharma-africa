# === Required ===
DATABASE_URL=postgresql://...neon.tech/neondb?sslmode=require

# === Egypt EDA (2captcha image CAPTCHA solver) ===
# Get from: https://2captcha.com/enterpage (after login → API key tab)
# Cost: ~$0.50-1.00 per 1000 CAPTCHAs (image type)
# Without this, EDA_EG scraper returns 0 records and logs a warning.
TWOCAPTCHA_KEY=REPLACE_ME

# === Angola ARMED (auth-gated portal) ===
# Get from ARMED admin team — requires Bearer JWT
# Without this, ARMED_AO scraper returns 0 records.
ARMED_API_TOKEN=REPLACE_ME

# === Intelligence brief ===
OPENROUTER_API_KEY=REPLACE_ME
